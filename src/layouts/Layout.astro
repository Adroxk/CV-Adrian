---
const { title = "Adrian | Programador Jr" } = Astro.props;
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Desarrollador frontend especializado en Astro y JavaScript. Enfocado en rendimiento y arquitectura modular.">
  <meta property="og:title" content="Adrian | Frontend Developer">
  <meta property="og:description" content="Portfolio profesional con proyectos en Astro y JavaScript.">
  <meta property="og:type" content="website">
  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  
  <script>
    (function () {
    const userPrefer = window.matchMedia("(prefers-color-scheme: dark)").matches;
    if (userPrefer) {
      document.documentElement.classList.add("dark");
    }
  })();
  </script>
</head>

  
  
  <body>
    <button id="theme-toggle" class="btn-Dm">Modo oscuro</button>
    <div class="background-glow"></div>
    <slot />
    <Footer />

       <script>
      const button = document.getElementById("theme-toggle");
      button?.addEventListener('click', () => {
        document.documentElement.classList.toggle("dark");
      });
  </script>
  </body>
  
  
<style>
  :root {
	--bg-color: #ffffff;
  --text-color: #111111;
	--tag-bg: #f3f4f6;
  --primary: #2563eb;
  --muted-text: #555;
  }

  html {
    background: var(--bg-color);
  }

  body {
    margin: 0;
  	font-family: 'Inter', system-ui, sans-serif;
    background: transparent;
  	color: var(--text-color);
  }

  .background-glow {
    position: fixed;
    top: 10%;
    left: 70%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
    opacity: 0.25;
    pointer-events: none;
    animation: pulse 6s infinite ease-in-out;
  }

  @keyframes pulse {
    0% { transform: scale(1);}
    50% { transform: scale(1.4);}
    100% { transform: scale(1);}
  }

  a {
    color: var(--primary);
    text-decoration: none;
  }

  
  .dark {
  --bg-color: #111111;
  --text-color: #f3f4f6;
  --tag-bg: #374151;
  --muted-text: #cbd5e1;
}

.btn-Dm {
  position: fixed;
  bottom: 1rem;
  right: 1rem;
  background: var(--primary);
  color: #fff;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 999px;
  cursor: pointer;
  font-size: 0.9rem;
}
  

</style>
 

</html>


