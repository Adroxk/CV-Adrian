---
export interface Props {
  title: string;
  description: string;
  tech: string[];
  link?: string;
}

const { title, description, tech, link } = Astro.props;
---

<article class="card">
  <h4>{title}</h4>
  <p>{description}</p>

  <div class="tech">
    {tech.map((item) => (
      <span>{item}</span>
    ))}
  </div>

  {link && (
    <a href={link} target="_blank">Ver proyecto →</a>
  )}
</article>

<style>
  .card {
    padding: 1.5rem;
    border: 1px solid var(--card-border);
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
  }

  h4 {
    margin: 0 0 0.5rem 0;
  }

  p {
    margin: 0 0 1rem 0;
    color: var(--muted-text);
    line-height: 1.6;
  }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tech span {
    background: var(--tag-bg);
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
  }

  a {
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>